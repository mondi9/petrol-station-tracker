rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Stations Collection
    match /stations/{stationId} {
      allow read: if true;
      allow create: if isAuth(); 
      allow delete: if isAdmin();
      allow update: if isAdmin() || (
        isAuth() && 
        request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'lastUpdated', 'waitTime', 'reports', 'prices', 'lastPriceUpdate', 'availability', 'queue', 'confirmations', 'flags', 'lastReporter'])
      );
    }

    // Reports Subcollection (Match anywhere for collectionGroup queries)
    match /{path=**}/reports/{reportId} {
      allow read: if true;
      allow create: if true; 
    }

    // Reviews Subcollection (Match anywhere for collectionGroup queries)
    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth();
      allow delete: if isAuth() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Users Collection (Profile)
    match /users/{userId} {
      // Users can read their own profile, Admins can read all
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() || (isAuth() && request.auth.uid == userId);
    }

    // Price Alerts Collection
    match /priceAlerts/{alertId} {
      // Users can read their own alerts
      allow read: if isAuth() && request.auth.uid == resource.data.userId;
      
      // Users can create alerts for themselves
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
      
      // Users can delete their own alerts
      allow delete: if isAuth() && request.auth.uid == resource.data.userId;
      
      // Users can update their own alerts (mark as triggered, etc.)
      allow update: if isAuth() && request.auth.uid == resource.data.userId;
    }

    // Activity Collection (Visits)
    match /activity/{activityId} {
      // Allow everyone to CREATE logs (used by logAppVisit)
      allow create: if true;
      
      // For verification phase: allow authenticated users to read (will tighten to isAdmin later)
      allow read: if isAuth() || isAdmin();
    }
  }
}
